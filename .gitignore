# Generated parsed resumes (runtime output)
parsed_resumes/

# Allow committing a curated, public resume dataset for GitHub Pages.
# Keep ALL parsed resumes ignored by default, then opt-in only the one folder we want public.
parsed_resumes/**
!parsed_resumes/
!parsed_resumes/shawn-becker-full-stack-developer-ai-ml-engineer/
!parsed_resumes/shawn-becker-full-stack-developer-ai-ml-engineer/*.json

