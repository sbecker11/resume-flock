# Copy to .env and fill in secrets (API keys, tokens). Only .env.example is committed; .env is gitignored.

# Backend (Express) server port; also used as Vite proxy target when VITE_API_PORT is unset. 3001 avoids conflict with 3000.
EXPRESS_PORT=3001

# Vite dev server port. 5174 avoids conflict with apps on 5173; change for more instances.
VITE_DEV_PORT=5174

# Target for Vite proxy to backend. Defaults to EXPRESS_PORT; set when running frontend dev alone.
# VITE_API_PORT=3001

# Parallax scale factor (0–1) for most distant cards. Closer cards have scale factor closer to 1
VITE_PARALLAX_SCALE_AT_MAX_Z=0.9

# Saturation scale factor (0–1) for most distant cards. Closer cards have saturation closer to 1.
VITE_SATURATION_AT_MAX_Z=0.6

# Brightness scale factor (0-1) for most distant cards. Closer cards have brightness closer to 1.
VITE_BRIGHTNESS_AT_MAX_Z=0.75

# Blur at max Z (0 = none). Linear from 0 at min Z to this value at max Z. Restart dev server after changing.
# VITE_BLUR_AT_MAX_Z=0

# Secrets — set real values in .env only; never commit .env.
# Figma API token: used by figma sync tooling (e.g. npm run figma-sync, npm run watch-figma).
# Get a personal access token from Figma → Account settings → Personal access tokens.
# AI_API_KEY=your-ai-api-key
FIGMA_TOKEN=users-figma-token
